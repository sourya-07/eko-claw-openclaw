# Google Gemini API Key - Obtained for free from Google AI Studio.
# Required for agent response formulation and direct answers.
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key if fallback is preferred.
# OPENAI_API_KEY=your_openai_api_key_here

# SQLite Database Location path (default points to server's data folder)
DATABASE_URL=./data/eko_support.db
